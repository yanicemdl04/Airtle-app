# ---------------------------------------------------------------------------
# Base de données PostgreSQL
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://airtel:airtel_secret@localhost:5433/airtel_money?schema=public"

# ---------------------------------------------------------------------------
# Authentification JWT
# ---------------------------------------------------------------------------
# Access token : durée de vie courte
JWT_SECRET="change-me-access-secret-min-32-chars-long"
JWT_EXPIRES_IN="15m"

# Refresh token : durée de vie longue + rotation
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_REFRESH_EXPIRES_IN="7d"

# ---------------------------------------------------------------------------
# Sécurité QR (signature HMAC SHA256)
# ---------------------------------------------------------------------------
QR_SECRET_KEY="change-me-qr-hmac-secret-min-32-chars-long"

# ---------------------------------------------------------------------------
# Serveur
# ---------------------------------------------------------------------------
# 3001 par défaut : le port 3000 est souvent occupé ou bloqué sous Windows.
PORT=3001
# 127.0.0.1 en dev local ; mettre 0.0.0.0 pour un téléphone sur le même Wi-Fi.
HOST=127.0.0.1
NODE_ENV=development

# Origines autorisées pour CORS (séparées par des virgules)
CORS_ORIGINS="http://localhost:3001,http://localhost:3000,http://localhost:8080,http://127.0.0.1:3001,http://127.0.0.1:3000,http://127.0.0.1:8080"
