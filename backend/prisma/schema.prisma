// Schéma Prisma — Plateforme de paiement mobile type Airtel Money
// Datasource PostgreSQL, client JavaScript généré.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Currency {
  USD
  CDF
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum TransactionType {
  SEND
  RECEIVE
  TOPUP
  WITHDRAW
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum AccountType {
  PERSONAL
  MERCHANT
}

enum CreationChannel {
  MOBILE
  USSD
}

// ---------------------------------------------------------------------------
// 1) USERS — identité utilisateur
// ---------------------------------------------------------------------------

model User {
  id                  String          @id @default(uuid()) @db.Uuid
  phoneHash           String          @unique @map("phone_hash")
  phoneEncrypted      Bytes           @map("phone_encrypted")
  nameEncrypted       Bytes           @map("name_encrypted")
  displayName         String          @map("display_name")
  avatarUrl           String?         @map("avatar_url")
  country             String?
  operator            String?
  pinHash             String          @map("pin_hash")
  accountType         AccountType     @default(PERSONAL) @map("account_type")
  failedPinAttempts   Int             @default(0) @map("failed_pin_attempts")
  lockedUntil         DateTime?       @map("locked_until")
  encryptionKeyId     Int             @default(1) @map("encryption_key_id")
  createdVia          CreationChannel @default(MOBILE) @map("created_via")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  wallets              Wallet[]
  qrCodes             QrCode[]
  sessions            UserSession[]
  sentTransactions    Transaction[]   @relation("SenderTransactions")
  receivedTransactions Transaction[]  @relation("ReceiverTransactions")
  auditLogs           AuditLog[]
  qrScans             QrScan[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// 2) WALLETS — portefeuille financier
// ---------------------------------------------------------------------------

model Wallet {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  balanceUsd      Decimal      @default(0) @map("balance_usd") @db.Decimal(18, 2)
  balanceCdf      Decimal      @default(0) @map("balance_cdf") @db.Decimal(18, 2)
  currencyDefault Currency     @default(CDF) @map("currency_default")
  status          WalletStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

// ---------------------------------------------------------------------------
// 3) TRANSACTIONS — table centrale
// ---------------------------------------------------------------------------

model Transaction {
  id             String            @id @default(uuid()) @db.Uuid
  senderId       String?           @map("sender_id") @db.Uuid
  receiverId     String?           @map("receiver_id") @db.Uuid
  amount         Decimal           @db.Decimal(18, 2)
  currency       Currency
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  fee            Decimal           @default(0) @db.Decimal(18, 2)
  reference      String            @unique
  // Empêche le rejeu d'une même opération (double transaction).
  idempotencyKey String            @unique @map("idempotency_key")
  createdAt      DateTime          @default(now()) @map("created_at")

  sender   User? @relation("SenderTransactions", fields: [senderId], references: [id])
  receiver User? @relation("ReceiverTransactions", fields: [receiverId], references: [id])

  logs TransactionLog[]

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("transactions")
}

// ---------------------------------------------------------------------------
// 4) QR_CODES — QR de paiement signés
// ---------------------------------------------------------------------------

model QrCode {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  token               String   @unique
  keyId               Int      @default(1) @map("key_id")
  revoked             Boolean  @default(false)
  revokeScheduledAt   DateTime? @map("revoke_scheduled_at")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans QrScan[]

  @@index([userId, revoked])
  @@map("qr_codes")
}

// ---------------------------------------------------------------------------
// 5) USER_SESSIONS — appareils connectés
// ---------------------------------------------------------------------------

model UserSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  deviceId     String   @map("device_id")
  ipAddress    String?  @map("ip_address")
  // Hash du refresh token (jamais stocké en clair) pour la rotation.
  refreshToken String   @map("refresh_token")
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("user_sessions")
}

// ---------------------------------------------------------------------------
// 6) TRANSACTION_LOGS — audit complet
// ---------------------------------------------------------------------------

model TransactionLog {
  id            String   @id @default(uuid()) @db.Uuid
  transactionId String?  @map("transaction_id") @db.Uuid
  action        String
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([action])
  @@map("transaction_logs")
}

// ---------------------------------------------------------------------------
// 7) QR_SCANS — audit des scans de QR
// ---------------------------------------------------------------------------

model QrScan {
  id                  String   @id @default(uuid()) @db.Uuid
  qrToken             String   @map("qr_token")
  scannerUserId       String   @map("scanner_user_id") @db.Uuid
  ipHash              String   @map("ip_hash")
  deviceIdHash        String?  @map("device_id_hash")
  resultedInPayment   Boolean  @default(false) @map("resulted_in_payment")
  createdAt           DateTime @default(now()) @map("created_at")

  scanner User @relation(fields: [scannerUserId], references: [id], onDelete: Cascade)
  qrCode  QrCode @relation(fields: [qrToken], references: [token], onDelete: Cascade)

  @@index([scannerUserId])
  @@index([qrToken])
  @@map("qr_scans")
}

// ---------------------------------------------------------------------------
// 8) PAY_INTENTS — tracking des intents de paiement (single-use)
// ---------------------------------------------------------------------------

model PayIntent {
  jti         String   @id
  consumed    Boolean  @default(false)
  expiresAt   DateTime @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")

  @@index([expiresAt])
  @@map("pay_intents")
}

// ---------------------------------------------------------------------------
// 9) AUDIT_LOG — immuable, signé en chaîne
// ---------------------------------------------------------------------------

model AuditLog {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String?  @map("user_id") @db.Uuid
  action   String
  metadata Json?
  prevHash String   @map("prev_hash")
  hash     String
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// 10) USSD_SESSIONS — sessions USSD (backup Redis)
// ---------------------------------------------------------------------------

model UssdSession {
  sessionId String   @id @map("session_id")
  phoneHash String   @map("phone_hash")
  state     String
  context   Json
  expiresAt DateTime @map("expires_at")

  @@index([phoneHash])
  @@map("ussd_sessions")
}